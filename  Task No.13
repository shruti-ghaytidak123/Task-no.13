        "\n",
        "# Q.6\n",
        "\n",
        "import numpy as np\n",
        "\n",
        "v1 = np.array([2, 4, 6, 8])\n",
        "v2 = np.array([1, 3, 5, 7])\n",
        "\n",
        "print(\"Vector 1:\", v1)\n",
        "print(\"Vector 2:\", v2)\n",
        "\n",
        "print(\"\\nAddition:\")\n",
        "print(v1 + v2)\n",
        "\n",
        "print(\"\\nSubtraction:\")\n",
        "print(v1 - v2)\n",
        "\n",
        "print(\"\\nElements-wise Multiplication:\")\n",
        "print(v1 * v2)\n",
        "\n",
        "print(\"\\nDot Product:\")\n",
        "print(np.dot(v1, v2))"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "pKNhA0fBTIFQ",
        "outputId": "286aa15b-cab2-4eb4-fb82-1d63cc64dc15"
      },
      "execution_count": null,
