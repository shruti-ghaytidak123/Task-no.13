      "cell_type": "code",
      "source": [
        "\n",
        "# Q.8\n",
        "\n",
        "import numpy as np\n",
        "A = np.random.randint(1, 101,(4, 4))\n",
        "print(\"Matrix:\")\n",
        "print(A)\n",
        "print(\"Shape:\", A.shape)\n",
        "print(\"Dimension:\", A.ndim)\n",
        "print(\"Size:\", A.size)\n",
        "print(\"Data Type:\", A.dtype)\n",
        "print(\"Minimum:\", A.min())\n",
        "print(\"Maximum:\", A.max())"
      ],
