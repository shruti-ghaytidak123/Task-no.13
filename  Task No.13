      "cell_type": "code",
      "source": [
        "\n",
        "# Q.10\n",
        "\n",
        "import numpy as np\n",
        "\n",
        "try:\n",
        "    n = int(input(\"Enter how many numbers to generate: \"))\n",
        "\n",
        "    arr = np.random.randint(10, 101, n)\n",
        "\n",
        "    print(\"\\nGenerated Array:\")\n",
        "    print(arr)\n",
        "\n",
        "    print(\"\\nMean:\", np.mean(arr))\n",
        "    print(\"Median:\", np.median(arr))\n",
        "    print(\"Standard Deviation:\", np.std(arr))\n",
        "    print(\"Minimum:\", np.min(arr))\n",
        "    print(\"Maximum:\", np.max(arr))\n",
        "\n",
        "    if n % 2 == 0:\n",
        "        arr2 = arr.reshape(2, n//2)\n",
        "        print(\"\\n2D Array:\")\n",
        "        print(arr2)\n",
        "\n",
        "        print(\"\\nRow-wise Sum:\")\n",
        "        print(np.sum(arr2, axis=1))\n",
        "    else:\n",
        "        print(\"\\nCannot reshape into a 2D array.\")\n",
        "\n",
        "except ValueError:\n",
        "    print(\"Please enter a valid integer.\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "syxB3hdFjtUb",
        "outputId": "b28356fc-2a90-4c81-9f1d-f37cfbd4bfd9"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Enter how many numbers to generate: 8\n",
            "\n",
