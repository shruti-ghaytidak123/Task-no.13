        "# Q.1\n",
        "\n",
        "import numpy as np\n",
        "\n",
        "a = np.array([10, 20, 30, 40, 50])\n",
        "b = np.array([[1, 2, 3],\n",
        "               [4, 5, 6]])\n",
        "print(\"1D Array:\")\n",
        "print(a)\n",
        "print(\"Shape:\", a.shape)\n",
        "print(\"Data Type:\", a.dtype)\n",
        "\n",
        "print(\"2D Array:\")\n",
        "print(b)\n",
        "print(\"Shape:\", b.shape)\n",
        "print(\"Data Type:\", b.dtype)"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "d9Vt-yJuAYBk",
