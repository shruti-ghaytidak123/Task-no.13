            "Median: 40.0\n",
            "Standard Deviation: 23.205602771744587\n",
            "Minimum: 20\n",
            "Maximum: 85\n",
            "\n",
            "2D Array:\n",
            "[[25 85 37 84]\n",
            " [39 20 41 57]]\n",
            "\n",
            "Row-wise Sum:\n",
            "[231 157]\n"
          ]
        }
      ]
