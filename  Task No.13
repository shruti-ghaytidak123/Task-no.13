        "\n",
        "# Q.9\n",
        "\n",
        "import numpy as np\n",
        "\n",
        "A = np.random.randint(1, 51, 20)\n",
        "\n",
        "print(\"1D Array:\")\n",
        "print(A)\n",
        "\n",
        "B = A.reshape(4,5)\n",
        "\n",
        "print(\"\\n4x5 Matrix:\")\n",
        "print(B)\n",
        "\n",
        "print(\"\\nSum:\", np.sum(B))\n",
        "print(\"Mean:\", np.mean(B))\n",
        "print(\"Standard Deviation:\", np.std(B))\n",
        "\n",
        "print(\"\\nMaximum value in each row:\")\n",
        "print(np.max(B, axis=1))"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "EouaOXbxjnjQ",
        "outputId": "bd1ac4f6-a292-44e2-e494-cb177abbdbaa"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
