        "\n",
        "# Q.3\n",
        "\n",
        "import numpy as np\n",
        "\n",
        "a = np.arange(0, 21, 1)\n",
        "b = np.arange(10, 51, 2)\n",
        "c = np.arange(5, 101, 5)\n",
        "\n",
        "print(\"0 to 20:\")\n",
        "print(a)\n",
        "\n",
        "print(\"\\nEven Number 10 to 50:\")\n",
        "print(b)\n",
        "\n",
        "print(\"\\n5 to 100(step 5):\")\n",
        "print(c)"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "tYRfltU_F4IE",
        "outputId": "ff103ef8-3426-45c3-d6dc-aecf77ffdf32"
      },
      "execution_count": null,
