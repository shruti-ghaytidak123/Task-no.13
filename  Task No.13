        "\n",
        "# Q.2\n",
        "\n",
        "import numpy as np\n",
        "a = np.zeros(8)\n",
        "b = np.ones((4, 4))\n",
        "c = np.zeros((3, 3))\n",
        "\n",
        "print(\"1D Array of Zeros:\")\n",
        "print(a)\n",
        "print(\"4×4 Array of Once:\")\n",
        "print(b)\n",
        "print(\"3×3 Matrix of Zeros:\")\n",
        "print(c)"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "zQRy8RE7AjFJ",
